#!/usr/bin/env bash

# Source this file from bash or zsh to make the Daylily CLI available in the
# current shell from a repo checkout.

__daylily_activate_is_sourced() {
  if [ -n "${ZSH_VERSION:-}" ]; then
    case "${ZSH_EVAL_CONTEXT:-}" in
      *:file|*:file:*) return 0 ;;
    esac
    return 1
  fi

  if [ -n "${BASH_VERSION:-}" ]; then
    [ "${BASH_SOURCE[0]}" != "$0" ]
    return
  fi

  return 1
}

if ! __daylily_activate_is_sourced; then
  echo "Error: this script must be sourced." >&2
  echo "Usage: source ./activate" >&2
  exit 1
fi

__daylily_activate_script_path() {
  if [ -n "${BASH_VERSION:-}" ]; then
    printf '%s\n' "${BASH_SOURCE[0]}"
    return 0
  fi

  if [ -n "${ZSH_VERSION:-}" ]; then
    eval 'printf "%s\n" "${(%):-%N}"'
    return 0
  fi

  return 1
}

__daylily_activate_prepend_path() {
  case ":${PATH}:" in
    *":$1:"*) ;;
    *) PATH="$1${PATH:+:${PATH}}" ;;
  esac
}

__daylily_activate_conda_is_function() {
  case "$(type conda 2>/dev/null)" in
    *"shell function"*|*"function"*) return 0 ;;
  esac
  return 1
}

__daylily_activate_conda_exe() {
  if [ -n "${CONDA_EXE:-}" ] && [ -x "${CONDA_EXE}" ]; then
    printf '%s\n' "${CONDA_EXE}"
    return 0
  fi

  if [ -n "${BASH_VERSION:-}" ]; then
    type -p conda
    return
  fi

  if [ -n "${ZSH_VERSION:-}" ]; then
    whence -p conda
    return
  fi

  command -v conda
}

__daylily_activate_load_conda() {
  if ! command -v conda >/dev/null 2>&1; then
    return 1
  fi

  if __daylily_activate_conda_is_function; then
    return 0
  fi

  local conda_exe conda_shell conda_hook conda_base
  conda_exe="$(__daylily_activate_conda_exe 2>/dev/null || true)"
  if [ -z "${conda_exe}" ]; then
    return 1
  fi

  if [ -n "${BASH_VERSION:-}" ]; then
    conda_shell="bash"
  elif [ -n "${ZSH_VERSION:-}" ]; then
    conda_shell="zsh"
  else
    conda_shell="posix"
  fi

  conda_hook="$("${conda_exe}" "shell.${conda_shell}" hook 2>/dev/null || "${conda_exe}" shell.posix hook 2>/dev/null || true)"
  if [ -n "${conda_hook}" ]; then
    eval "${conda_hook}"
    return 0
  fi

  conda_base="$("${conda_exe}" info --base 2>/dev/null || true)"
  if [ -n "${conda_base}" ] && [ -f "${conda_base}/etc/profile.d/conda.sh" ]; then
    . "${conda_base}/etc/profile.d/conda.sh"
    return 0
  fi

  return 1
}

__daylily_activate_dayec_exists() {
  command -v conda >/dev/null 2>&1 || return 1
  conda env list 2>/dev/null | awk '{print $1}' | grep -qx 'DAY-EC'
}

__daylily_activate_env_yaml() {
  printf '%s\n' "${DAYLILY_EC_REPO_ROOT}/environment.yaml"
}

__daylily_activate_refresh_command_cache() {
  hash -r 2>/dev/null || true
  rehash 2>/dev/null || true
}

__daylily_activate_dayec_cli_path() {
  if [ "${CONDA_DEFAULT_ENV:-}" = "DAY-EC" ] && [ -n "${CONDA_PREFIX:-}" ]; then
    if [ -x "${CONDA_PREFIX}/bin/daylily-ec" ]; then
      printf '%s\n' "${CONDA_PREFIX}/bin/daylily-ec"
      return 0
    fi
  fi

  return 1
}

__daylily_activate_external_cli_path() {
  local cli_path dayec_cli_path
  dayec_cli_path="$(__daylily_activate_dayec_cli_path 2>/dev/null || true)"

  if [ -n "${BASH_VERSION:-}" ]; then
    cli_path="$(type -P daylily-ec 2>/dev/null || true)"
  elif [ -n "${ZSH_VERSION:-}" ]; then
    cli_path="$(whence -p daylily-ec 2>/dev/null || true)"
  else
    cli_path="$(command -v daylily-ec 2>/dev/null || true)"
  fi

  if [ -n "${cli_path}" ] && [ "${cli_path}" != "${dayec_cli_path}" ]; then
    printf '%s\n' "${cli_path}"
  fi
}

__daylily_activate_cli_smoke_test() {
  [ -n "${1:-}" ] || return 1
  [ -x "$1" ] || return 1
  "$1" version >/dev/null 2>&1
}

__daylily_activate_dayec_cli_smoke_test() {
  local cli_path
  cli_path="$(__daylily_activate_dayec_cli_path 2>/dev/null || true)"
  if [ -n "${cli_path}" ] && [ -x "${cli_path}" ]; then
    "${cli_path}" version >/dev/null 2>&1
    return $?
  fi

  __daylily_activate_load_conda || return 1
  __daylily_activate_dayec_exists || return 1
  conda run -n DAY-EC daylily-ec version >/dev/null 2>&1
}

__daylily_activate_dayec_pcluster_smoke_test() {
  local pcluster_path

  if [ "${CONDA_DEFAULT_ENV:-}" = "DAY-EC" ] && [ -n "${CONDA_PREFIX:-}" ]; then
    pcluster_path="${CONDA_PREFIX}/bin/pcluster"
    if [ -x "${pcluster_path}" ]; then
      "${pcluster_path}" version >/dev/null 2>&1
      return $?
    fi
  fi

  __daylily_activate_load_conda || return 1
  __daylily_activate_dayec_exists || return 1
  conda run -n DAY-EC pcluster version >/dev/null 2>&1
}

__daylily_activate_dayec_aws_smoke_test() {
  local aws_path

  if [ "${CONDA_DEFAULT_ENV:-}" = "DAY-EC" ] && [ -n "${CONDA_PREFIX:-}" ]; then
    aws_path="${CONDA_PREFIX}/bin/aws"
    if [ -x "${aws_path}" ]; then
      "${aws_path}" --version >/dev/null 2>&1
      return $?
    fi
  fi

  __daylily_activate_load_conda || return 1
  __daylily_activate_dayec_exists || return 1
  conda run -n DAY-EC aws --version >/dev/null 2>&1
}

__daylily_activate_dayec_ssm_plugin_smoke_test() {
  local plugin_path

  if [ "${CONDA_DEFAULT_ENV:-}" = "DAY-EC" ] && [ -n "${CONDA_PREFIX:-}" ]; then
    plugin_path="${CONDA_PREFIX}/bin/session-manager-plugin"
    if [ -x "${plugin_path}" ]; then
      "${plugin_path}" >/dev/null 2>&1
      return $?
    fi
  fi

  __daylily_activate_load_conda || return 1
  __daylily_activate_dayec_exists || return 1
  conda run -n DAY-EC session-manager-plugin >/dev/null 2>&1
}

__daylily_activate_dayec_node_smoke_test() {
  local node_path

  if [ "${CONDA_DEFAULT_ENV:-}" = "DAY-EC" ] && [ -n "${CONDA_PREFIX:-}" ]; then
    node_path="${CONDA_PREFIX}/bin/node"
    if [ -x "${node_path}" ]; then
      "${node_path}" --version >/dev/null 2>&1
      return $?
    fi
  fi

  __daylily_activate_load_conda || return 1
  __daylily_activate_dayec_exists || return 1
  conda run -n DAY-EC python -c "import os, sys; p = os.path.join(sys.prefix, 'bin', 'node'); raise SystemExit(0 if os.path.isfile(p) and os.access(p, os.X_OK) else 1)" >/dev/null 2>&1
}

__daylily_activate_dayec_runtime_smoke_test() {
  __daylily_activate_dayec_cli_smoke_test || return 1
  __daylily_activate_dayec_aws_smoke_test || return 1
  __daylily_activate_dayec_node_smoke_test || return 1
  __daylily_activate_dayec_pcluster_smoke_test || return 1
  __daylily_activate_dayec_ssm_plugin_smoke_test
}

__daylily_activate_activate_dayec() {
  __daylily_activate_load_conda || return 1

  if [ "${CONDA_DEFAULT_ENV:-}" = "DAY-EC" ] && [ -n "${CONDA_PREFIX:-}" ]; then
    return 0
  fi

  conda activate DAY-EC >/dev/null 2>&1 || return 1
  __daylily_activate_refresh_command_cache
}

__daylily_activate_create_dayec() {
  local env_yaml

  env_yaml="$(__daylily_activate_env_yaml)"
  if [ ! -f "${env_yaml}" ]; then
    echo "Error: DAY-EC bootstrap spec not found at ${env_yaml}." >&2
    return 1
  fi

  echo "Creating DAY-EC from ${env_yaml} ..." >&2
  conda env create -n DAY-EC -f "${env_yaml}"
}

__daylily_activate_update_dayec() {
  local env_yaml

  env_yaml="$(__daylily_activate_env_yaml)"
  if [ ! -f "${env_yaml}" ]; then
    echo "Error: DAY-EC bootstrap spec not found at ${env_yaml}." >&2
    return 1
  fi

  echo "Updating DAY-EC from ${env_yaml} ..." >&2
  conda env update -n DAY-EC -f "${env_yaml}"
}

__daylily_activate_install_repo_into_dayec() {
  local editable_spec
  editable_spec="${DAYLILY_EC_REPO_ROOT}[dev]"
  echo "Installing daylily-ephemeral-cluster into DAY-EC from ${editable_spec} ..." >&2
  conda run -n DAY-EC python -m pip install --editable "${editable_spec}" || return 1
  __daylily_activate_refresh_command_cache
}

__daylily_activate_bootstrap_dayec() {
  __daylily_activate_load_conda || {
    echo "Error: conda is not available in this shell." >&2
    return 1
  }

  if ! __daylily_activate_dayec_exists; then
    __daylily_activate_create_dayec || return 1
  fi

  __daylily_activate_activate_dayec || {
    echo "Error: failed to activate the DAY-EC conda environment." >&2
    return 1
  }

  if __daylily_activate_dayec_runtime_smoke_test; then
    return 0
  fi

  __daylily_activate_update_dayec || {
    echo "Error: failed to update the DAY-EC conda environment." >&2
    return 1
  }

  __daylily_activate_install_repo_into_dayec || {
    echo "Error: failed to install daylily-ephemeral-cluster into DAY-EC." >&2
    return 1
  }

  if ! __daylily_activate_dayec_runtime_smoke_test; then
    echo "Error: DAY-EC is active but required runtime checks still failed." >&2
    echo "Repair with: conda env update -n DAY-EC -f ${DAYLILY_EC_REPO_ROOT}/environment.yaml" >&2
    return 1
  fi

  return 0
}

__daylily_activate_ensure_dayec_ready() {
  if [ "${__daylily_activate_dayec_ready:-0}" = "1" ]; then
    return 0
  fi

  if __daylily_activate_bootstrap_dayec; then
    __daylily_activate_dayec_ready=1
    return 0
  fi

  return 1
}

__daylily_activate_repo_root="$(
  cd "$(dirname "$(__daylily_activate_script_path)")" && pwd
)"
export DAYLILY_EC_REPO_ROOT="${__daylily_activate_repo_root}"
export DAYLILY_EC_ACTIVE="1"

__daylily_activate_prepend_path "${DAYLILY_EC_REPO_ROOT}/bin"
export PATH

__daylily_activate_dayec_ready=0
if ! __daylily_activate_ensure_dayec_ready; then
  echo "Warning: DAY-EC bootstrap did not complete; daylily-ec will only use a global PATH install if it passes a version smoke test." >&2
fi

daylily-ec() {
  local cli_path

  if __daylily_activate_ensure_dayec_ready; then
    cli_path="$(__daylily_activate_dayec_cli_path 2>/dev/null || true)"
    if [ -n "${cli_path}" ] && [ -x "${cli_path}" ]; then
      "${cli_path}" "$@"
      return $?
    fi

    conda run -n DAY-EC daylily-ec "$@"
    return $?
  fi

  cli_path="$(__daylily_activate_external_cli_path)"
  if [ -n "${cli_path}" ] && __daylily_activate_cli_smoke_test "${cli_path}"; then
    "${cli_path}" "$@"
    return $?
  fi

  echo "Error: DAY-EC is not ready and no working daylily-ec executable was found." >&2
  echo "Fix conda and re-run 'source ./activate', or install the repo into DAY-EC with ./bin/init_dayec." >&2
  return 1
}

if [ "${CONDA_DEFAULT_ENV:-}" = "DAY-EC" ] && __daylily_activate_dayec_runtime_smoke_test; then
  echo "DAY-EC activated. daylily-ec, aws, pcluster, and session-manager-plugin are available in this shell."
elif cli_path="$(__daylily_activate_external_cli_path)" && [ -n "${cli_path}" ] && __daylily_activate_cli_smoke_test "${cli_path}"; then
  echo "Repo tools added to PATH. daylily-ec is available via a validated PATH install."
else
  echo "Repo tools added to PATH. daylily-ec will retry DAY-EC bootstrap or fail with repair guidance."
fi
