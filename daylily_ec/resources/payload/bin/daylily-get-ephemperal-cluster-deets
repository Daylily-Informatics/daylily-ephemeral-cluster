#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: daylily-get-ephemperal-cluster-deets [-h|--help]

Prints a short reminder on how to fetch cluster details using the AWS ParallelCluster CLI.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

echo "Use the ParallelCluster UI, or:"
echo "  pcluster list-clusters --region <region>"
echo "  pcluster describe-cluster --region <region> -n <cluster-id>"

